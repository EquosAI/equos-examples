# Server-side API key (never exposed to the browser).
EQUOS_API_KEY="your equos api key"

# Character to converse with (created in Equos Studio or via @equos/node-sdk).
EQUOS_CHARACTER_ID="your equos character id"

# Optional — override the Equos API endpoint (defaults to https://api.equos.ai).
# EQUOS_ENDPOINT="https://api.equos.ai"
